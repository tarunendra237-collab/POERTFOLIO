  .chatbot-msg-user span {
    background: #0d4f76;
    color: #eef5ff;
    padding: 10px 14px;
    border-radius: 14px;
    max-width: 85%;
    word-wrap: break-word;
    font-size: 0.95rem;
    line-height: 1.4;
    box-shadow: 0 1px 4px rgba(5, 144, 255, 0.25);
  }
  
  .chatbot-msg-bot span {
    background: #121f3d;
    color: #e9edf7;
    padding: 10px 14px;
    border-radius: 14px;
    max-width: 85%;
    word-wrap: break-word;
    font-size: 0.95rem;
    line-height: 1.4;
    box-shadow: 0 1px 2px rgba(0,0,0,0.35);
