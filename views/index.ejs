  <script>
    document.addEventListener('DOMContentLoaded', () => {
      document.querySelectorAll('.circle-chart').forEach(chart => {
        const target = Number(chart.getAttribute('data-value'));
        const svgCircle = chart.querySelector('svg circle:nth-child(2)');
        const text = chart.querySelector('.circle-text');
        const circumference = 2 * Math.PI * 52;
        let current = 0;
        const interval = setInterval(() => {
          if (current >= target) { clearInterval(interval); return; }
          current += 1;
          const offset = circumference - (current / 100) * circumference;
          svgCircle.style.strokeDashoffset = offset;
          text.textContent = `${current}%`;
        }, 12);
      });
    });
  </script>
