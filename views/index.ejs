  <!-- Chatbot widget -->
  <style>
  #chatbot-widget {position: fixed; right: 20px; bottom: 20px; width: 320px; max-height: 430px; box-shadow: 0 6px 14px rgba(0,0,0,0.28); border-radius: 12px; overflow: hidden; font-family: Arial, sans-serif; z-index: 999; display: none;}
  #chatbot-header {background: #0d6efd; color: #fff; padding: 9px 12px; font-size: 0.95rem; display: flex; justify-content: space-between; align-items: center;}
  #chatbot-toggle {position: fixed; right: 20px; bottom: 20px; width: 56px; height: 56px; border-radius: 50%; background: #0d6efd; color: #fff; border: 0; box-shadow: 0 5px 15px rgba(0,0,0,0.3); cursor: pointer; z-index: 1000;}
  #chatbot-messages {background: #f7f9ff; height: 290px; overflow-y: auto; padding: 10px; }
  .chatbot-message {margin: 6px 0; line-height: 1.4;}
  .chatbot-msg-user {text-align: right;}
  .chatbot-msg-user span, .chatbot-msg-bot span {display: inline-block; padding: 6px 10px; border-radius: 12px; max-width: 80%;}
  .chatbot-msg-user span {background: #0d6efd; color: #fff;}
  .chatbot-msg-bot span {background: #e9ecef; color: #212529;}
  #chatbot-input {display: flex; border-top: 1px solid #dee2e6;}
  #chatbot-input-field {flex: 1; border: none; padding: 9px 10px; font-size: 0.92rem;}
  #chatbot-input-field:focus {outline: none;}
  #chatbot-send {border: none; background: #0d6efd; color: #fff; padding: 0 14px; cursor: pointer;}
  </style>

  <div id="chatbot-widget">
    <div id="chatbot-header">
      <div>Chatbot</div>
      <button id="chatbot-close" style="background: transparent; border: 0; color: white; font-size: 16px;">×</button>
    </div>
    <div id="chatbot-messages"></div>
    <div id="chatbot-input">
      <input id="chatbot-input-field" type="text" placeholder="Type a message..." aria-label="Chatbot message input" />
      <button id="chatbot-send">Send</button>
    </div>
  </div>

  <button id="chatbot-toggle" title="Open Chatbot">💬</button>

  <script>
    const chatToggle = document.getElementById('chatbot-toggle');
    const chatWidget = document.getElementById('chatbot-widget');
    const chatClose = document.getElementById('chatbot-close');
    const chatMessages = document.getElementById('chatbot-messages');
    const chatInput = document.getElementById('chatbot-input-field');
    const chatSend = document.getElementById('chatbot-send');

    const botResponses = [{
      patterns: [/hi|hello|hey/i],
      response: 'Hi there! I am live on your portfolio. How can I help you today?'
    }, {
      patterns: [/project|work/i],
      response: 'I have built responsive web apps and portfolios. Ask me about my skills or latest project.'
    }, {
      patterns: [/skill|tech/i],
      response: 'I work with HTML, CSS, JavaScript, Node.js, Express, and MongoDB. I also enjoy learning new tools.'
    }, {
      patterns: [/default/i],
      response: 'That sounds interesting! Tell me more or ask for specific details about the site.'
    }];

    function addMessage(text, isUser) {
      const item = document.createElement('div');
      item.className = `chatbot-message ${isUser ? 'chatbot-msg-user' : 'chatbot-msg-bot'}`;
      const bubble = document.createElement('span');
      bubble.textContent = text;
      item.appendChild(bubble);
      chatMessages.appendChild(item);
      chatMessages.scrollTop = chatMessages.scrollHeight;
    }

    function getBotReply(message) {
      const lower = message.trim();
      for (const rule of botResponses) {
        if (rule.patterns.some(p => p.test(lower))) {
          return rule.response;
        }
      }
      return 'I am learning! Please try a different question or ask about "projects" or "skills".';
    }

    function sendChat() {
      const text = chatInput.value.trim();
      if (!text) return;
      addMessage(text, true);
      chatInput.value = '';
      setTimeout(() => addMessage(getBotReply(text), false), 450);
    }

    chatToggle.addEventListener('click', () => { chatWidget.style.display = 'block'; chatToggle.style.display = 'none'; chatInput.focus(); });
    chatClose.addEventListener('click', () => { chatWidget.style.display = 'none'; chatToggle.style.display = 'block'; });
    chatSend.addEventListener('click', sendChat);
    chatInput.addEventListener('keydown', e => { if (e.key === 'Enter') sendChat(); });
  </script>

  <script>
document.getElementById("contact-form").addEventListener("submit", async function(e) {
  e.preventDefault();

  const form = e.target;

  const data = {
    name: form.name.value,
    email: form.email.value,
    subject: form.subject.value,
    message: form.message.value
  };

  try {
    const res = await fetch("http://localhost:8080/contact", {
      method: "POST",
      headers: {
        "Content-Type": "application/json"
      },
      body: JSON.stringify(data)
    });

    const result = await res.text();
    alert(result);
    form.reset();

  } catch (err) {
    alert("Error sending message ❌");
  }
});
</script>
